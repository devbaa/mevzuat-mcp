    {
      "name": "search_mevzuat",
      "description": "Unified search/list endpoint over bedesten.adalet.gov.tr legislation data.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Primary full-text query (phrase)." },
          "filters": {
            "type": "object",
            "properties": {
              "mevzuat_adi": { "type": "string" },
              "mevzuat_no": { "type": "string" },
              "mevzuat_tur": { "type": "string" },
              "basliktaAra": { "type": "boolean" },
              "tamCumle": { "type": "boolean" },
              "resmi_gazete_tarihi_start": { "type": "string" },
              "resmi_gazete_tarihi_end": { "type": "string" },
              "resmi_gazete_sayisi": { "type": "string" },
              "page": { "type": "integer" },
              "page_size": { "type": "integer" }
            }
          }
        },
        "required": []
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string", "description": "mevzuatId" },
                "number": { "type": "string" },
                "title": { "type": "string" },
                "type": { "type": "string" },
                "official_gazette_date": { "type": "string" },
                "gerekce_id": { "type": "string" }
              }
            }
          },
          "total_results": { "type": "integer" },
          "page": { "type": "integer" },
          "error_message": { "type": "string" }
        }
      }
    },
