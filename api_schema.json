              "type": "object",
              "properties": {
                "id": { "type": "string", "description": "Composite identifier from mevzuat_no + mevzuat_tur + mevzuat_tertip." },
                "number": { "type": "string" },
                "title": { "type": "string" },
                "acceptance_date": { "type": "string" },
                "official_gazette_date": { "type": "string" },
                "official_gazette_issue": { "type": "string" },
                "type_code": { "type": "integer" },
                "tertip": { "type": "string" },
                "url": { "type": "string" }
              }
            }
          },
          "total_results": { "type": "integer" },
          "current_page": { "type": "integer" },
          "page_size": { "type": "integer" },
          "total_pages": { "type": "integer" },
          "error_message": { "type": "string" }
        }
      }
    },
