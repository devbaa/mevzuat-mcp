{
  "repo_summary": {
    "primary_server": "FastMCP app exposes 26 tools across mevzuat.gov.tr and bedesten.adalet.gov.tr",
    "core_files": [
      "mevzuat_mcp_server.py",
      "mevzuat_client.py",
      "bedesten_client.py",
