  "tool_to_import_job_mapping": [
    {"tool_family":"mevzuat.gov.tr search_*","php_job":"MevzuatSearchImportJob","mode":"list","next_step":"enqueue content job per result"},
    {"tool_family":"mevzuat.gov.tr get_*_content","php_job":"MevzuatFullContentImportJob","mode":"full_content","next_step":"upsert document + version"},
    {"tool_family":"mevzuat.gov.tr search_within_*","php_job":"MevzuatSearchWithinAuditJob","mode":"detail/semantic","next_step":"persist retrieval lineage and matched article metadata"},
    {"tool_family":"bedesten search_mevzuat","php_job":"BedestenSearchImportJob","mode":"list","next_step":"enqueue get_content/gerekce/tree jobs"},
    {"tool_family":"bedesten get_mevzuat_content","php_job":"BedestenFullContentImportJob","mode":"full_content","next_step":"upsert content + hash"},
    {"tool_family":"bedesten get_mevzuat_gerekce","php_job":"BedestenGerekceImportJob","mode":"content","next_step":"store as related document variant"},
    {"tool_family":"bedesten get_mevzuat_madde_tree","php_job":"BedestenTreeImportJob","mode":"detail","next_step":"store tree JSON for structure and madde IDs"}
  ],
  "database_schema": {
    "implemented_in": "migrations/20260422_000001_create_ingestion_tables.sql",
    "dedupe_keys": [
      "documents(unique source_id,document_type,tertip,no,madde_no,raw_identifier)",
      "document_versions(unique document_id,content_hash)",
      "fetch_requests(unique job_id,source_id,endpoint_name,page_number,cursor_value,request_fingerprint)"
    ]
  },
  "php_architecture": {
    "files": [
      "public/downloader.php",
      "src/SourceRegistry.php",
      "src/Downloader/AbstractSourceDownloader.php",
      "src/Downloader/MevzuatGovDownloader.php",
      "src/Http/HttpClient.php",
      "src/RateLimit/ThrottlePolicy.php",
      "src/Repository/DocumentRepository.php",
      "src/Repository/FetchJobRepository.php",
      "src/Service/FetchJobRunner.php",
      "src/Logger/ImportLogger.php",
      "config/sources.php"
    ],
    "runtime": "PHP 8.2+, PDO + cURL"
  },
  "download_flow": [
    "Create fetch_job and persist operator options (source, mode, filters, max pages/items, throttle profile)",
    "Page through list endpoint; persist each request in fetch_requests with params+status+timings",
    "Normalize identity fields from each result; enqueue detail/full-content fetch",
    "Run full content retrieval with HTML/DOC/PDF fallback strategy and source flags",
    "Compute SHA-256 content_hash and upsert documents",
    "If hash changed, insert document_versions",
    "Persist metadata/tree/gerekce in document_metadata",
    "Persist rate_limit_events and retry attempts",
    "Mark job finished with totals, errors, and stop reason"
  ],
  "rate_limit_policy": {
    "mevzuat.gov.tr": {
      "list_requests": {"min_delay_ms": 1200, "max_rpm": 30, "max_rph": 1200, "burst_size": 2, "jitter_ms": [150, 450], "concurrency": 1},
      "detail_requests": {"min_delay_ms": 2000, "max_rpm": 20, "max_rph": 800, "burst_size": 1, "jitter_ms": [250, 700], "concurrency": 1},
      "content_requests": {"min_delay_ms": 3500, "max_rpm": 12, "max_rph": 400, "burst_size": 1, "jitter_ms": [350, 1000], "concurrency": 1}
    },
    "bedesten.adalet.gov.tr": {
      "list_requests": {"min_delay_ms": 900, "max_rpm": 40, "max_rph": 1600, "burst_size": 3, "jitter_ms": [100, 300], "concurrency": 1},
      "detail_requests": {"min_delay_ms": 1500, "max_rpm": 25, "max_rph": 900, "burst_size": 1, "jitter_ms": [150, 500], "concurrency": 1},
      "content_requests": {"min_delay_ms": 2500, "max_rpm": 15, "max_rph": 500, "burst_size": 1, "jitter_ms": [300, 900], "concurrency": 1}
    }
  },
  "pagination_policy": {
    "search_* mevzuat.gov.tr": {"paging_supported": true, "paging_style": "page_number", "request_fields": ["page_number", "page_size"], "safe_defaults": {"page_size": 25, "max_pages_per_job": 100, "max_items_per_job": 2500}},
    "search_mevzuat bedesten": {"paging_supported": true, "paging_style": "page_number", "request_fields": ["page", "page_size"], "safe_defaults": {"page_size": 25, "max_pages_per_job": 120, "max_items_per_job": 3000}},
    "content/detail endpoints": {"paging_supported": false, "paging_style": "none", "request_fields": [], "safe_defaults": {"page_size": 1, "max_pages_per_job": 1, "max_items_per_job": 500}}
  },
  "retry_policy": {
    "max_attempts": 5,
    "timeouts_seconds": [30, 45, 60],
    "backoff": {
      "on_429_seconds": [60, 180, 600],
      "on_403_seconds": [300, 1800],
      "on_5xx_seconds": [10, 30, 90, 180],
      "on_timeout_seconds": [10, 30, 90]
    },
    "circuit_breaker": {
      "consecutive_failures_threshold": 12,
      "open_state_seconds": 900
    }
  },
  "example_code": {
    "status": "added scaffold PHP classes and SQL migration in repository"
  },
  "risks": [
    "Playwright-backed mevzuat flow in Python depends on browser/cookies; direct PHP replacement should use REST/search endpoints where possible and fallback to HTML fetch carefully.",
    "PDF OCR path is expensive and higher ban-risk due to large payloads; keep low concurrency and hard caps.",
    "Semantic search in existing MCP performs content fetch + embedding; importer should avoid triggering semantic fetch unless explicitly requested."
  ],
  "implementation_notes": [
    "Values for safe defaults are conservative and inferred unless directly constrained by code comments/Field validators.",
    "Store raw request/response envelope snapshots for replayability and auditing.",
    "Persist source flags on each document row: source_tool, source_variant, fetch_transport, used_fallback, used_cache, semantic_related, full_download_completed."
  ]
}
