    "important_branching": {
      "tertip_fallback": ["requested tertip", "5", "3"],
      "content_transport_order": ["HTML iframe first", "DOC", "PDF", "OCR fallback for PDF when configured"],
      "semantic_branch": "search_within_* chooses semantic vector path vs keyword path",
      "cache_branch": "in-memory content cache and embedding cache short-circuit remote calls"
    }
