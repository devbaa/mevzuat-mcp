    "observed_data_paths": [
      "search/list over mevzuat.gov.tr DataTables API",
      "full-content fetch via HTML iframe, DOC, PDF (+ OCR)",
      "bedesten REST search/content/gerekce/tree",
      "search-within workflows loading full content then article/chunk parsing"
